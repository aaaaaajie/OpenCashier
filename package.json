{
  "name": "payment-platform",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "dev": "pnpm --parallel --filter @payment-platform/api --filter @payment-platform/web dev",
    "dev:api": "pnpm --filter @payment-platform/api dev",
    "dev:web": "pnpm --filter @payment-platform/web dev",
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "test:tunnel": "node --test scripts/alipay-callback-tunnel.test.mjs",
    "tunnel:alipay": "node scripts/start-alipay-local-callback.mjs",
    "smoke:merchant": "node scripts/smoke-merchant-api.mjs",
    "prisma:generate": "pnpm --filter @payment-platform/api prisma:generate",
    "prisma:migrate:dev": "pnpm --filter @payment-platform/api prisma:migrate:dev",
    "prisma:studio": "pnpm --filter @payment-platform/api prisma:studio",
    "prisma:db:push": "pnpm --filter @payment-platform/api exec prisma db push --schema prisma/schema.prisma"
  }
}
