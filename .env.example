APP_SECRET=local-dev-app-secret
APP_BASE_URL=http://localhost:3000
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/payment_platform?schema=public
WEB_BASE_URL=http://localhost:5173
VITE_API_BASE_URL=http://localhost:3000/api/v1

# Optional provider credentials
# 当前支付宝接入使用“公钥模式”，不是证书模式
# ALIPAY_APP_ID: 支付宝开放平台应用 ID
ALIPAY_APP_ID=
# 可直接覆盖支付宝异步通知完整地址，例如 https://abc.trycloudflare.com/api/v1/notify/alipay
ALIPAY_NOTIFY_URL=
# 也可只填公网基础地址，程序会自动拼接 /api/v1/notify/alipay
ALIPAY_NOTIFY_BASE_URL=
# 支持两种方式：
# 1. 直接填 PEM 字符串，使用 \n 表示换行
# 2. 填本地文件路径，例如 ./certs/alipay/app-private-key.pem
# ALIPAY_PRIVATE_KEY: 应用私钥
ALIPAY_PRIVATE_KEY=
# ALIPAY_PUBLIC_KEY: 支付宝公钥，不是应用公钥
ALIPAY_PUBLIC_KEY=
# 沙箱请以开放平台当前展示为准，例如 https://openapi-sandbox.dl.alipaydev.com/gateway.do
# 生产: https://openapi.alipay.com/gateway.do
ALIPAY_GATEWAY=
STRIPE_SECRET_KEY=
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
WECHATPAY_APP_ID=
WECHATPAY_MCH_ID=
WECHATPAY_API_V3_KEY=
WECHATPAY_PRIVATE_KEY=
