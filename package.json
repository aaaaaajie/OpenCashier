{
  "name": "opencashier",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "dev": "pnpm --parallel --filter @opencashier/api --filter @opencashier/web dev",
    "dev:api": "pnpm --filter @opencashier/api dev",
    "dev:merchant-quickstart": "pnpm --filter @opencashier/merchant-quickstart dev",
    "dev:web": "pnpm --filter @opencashier/web dev",
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "test:tunnel": "node --test scripts/alipay-callback-tunnel.test.mjs",
    "tunnel:alipay": "node scripts/start-alipay-local-callback.mjs",
    "smoke:merchant": "node scripts/smoke-merchant-api.mjs",
    "changelog:validate": "node scripts/changelog.mjs validate",
    "changelog:draft": "node scripts/changelog.mjs draft --write",
    "changelog:release": "node scripts/changelog.mjs release",
    "prisma:generate": "pnpm --filter @opencashier/api prisma:generate",
    "prisma:migrate:dev": "pnpm --filter @opencashier/api prisma:migrate:dev",
    "prisma:studio": "pnpm --filter @opencashier/api prisma:studio",
    "prisma:db:push": "pnpm --filter @opencashier/api prisma:db:push"
  }
}
