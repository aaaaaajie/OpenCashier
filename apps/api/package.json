{
  "name": "@opencashier/api",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "predev": "pnpm --filter @opencashier/wechatpay-sdk build",
    "dev": "nest start --watch",
    "prebuild": "pnpm --filter @opencashier/wechatpay-sdk build",
    "build": "nest build",
    "pretypecheck": "pnpm --filter @opencashier/wechatpay-sdk build",
    "start": "node dist/main.js",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "prisma:generate": "sh -lc 'set -a && . ../../.env && set +a && prisma generate --schema prisma/schema.prisma'",
    "prisma:migrate:dev": "sh -lc 'set -a && . ../../.env && set +a && prisma migrate dev --schema prisma/schema.prisma'",
    "prisma:studio": "sh -lc 'set -a && . ../../.env && set +a && prisma studio --schema prisma/schema.prisma'",
    "prisma:db:push": "sh -lc 'set -a && . ../../.env && set +a && prisma db push --schema prisma/schema.prisma'"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.6",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.1.6",
    "@nestjs/platform-express": "^11.1.6",
    "@nestjs/schedule": "^6.0.0",
    "@nestjs/swagger": "^11.2.0",
    "@opencashier/wechatpay-sdk": "workspace:*",
    "@prisma/client": "^6.16.2",
    "alipay-sdk": "^4.3.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.2",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "stripe": "^20.4.1",
    "swagger-ui-express": "^5.0.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.10",
    "@nestjs/testing": "^11.1.6",
    "@types/express": "^5.0.3",
    "@types/node": "^22.18.1",
    "prisma": "^6.16.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.8.3"
  }
}
