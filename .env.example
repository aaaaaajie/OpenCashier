APP_SECRET=local-dev-app-secret
PLATFORM_CONFIG_MASTER_KEY=local-dev-platform-config-master-key
APP_BASE_URL=http://localhost:3000
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/cashier?schema=public
WEB_BASE_URL=http://localhost:5173
VITE_API_BASE_URL=http://localhost:3000/api/v1
ADMIN_USERNAME=admin
ADMIN_PASSWORD=local-dev-admin-password
ENABLE_DEMO_DATA=1

# 支付渠道配置请在后台“系统设置”页维护。
# 支付渠道回调地址由系统基于 APP_BASE_URL 内置生成，不再单独配置。
