PORT=4100
APP_BASE_URL=http://127.0.0.1:4100
OPENCASHIER_API_BASE_URL=http://127.0.0.1:3000/api/v1
OPENCASHIER_APP_ID=demo_app
OPENCASHIER_APP_SECRET=demo_app_secret
OPENCASHIER_NOTIFY_URL=http://127.0.0.1:4100/notify/opencashier
OPENCASHIER_ALLOWED_CHANNELS=alipay_page

# Must match ADMIN_USERNAME / ADMIN_PASSWORD in the OpenCashier API root .env.
OPENCASHIER_ADMIN_USERNAME=admin
OPENCASHIER_ADMIN_PASSWORD=admin123456

# When enabled, the startup script provisions one app-scoped provider config through:
# PUT /api/v1/admin/merchants/:appId/platform-configs
# POST /api/v1/admin/merchants/:appId/platform-configs/:configKey/validate
# POST /api/v1/admin/merchants/:appId/platform-configs/:configKey/activate
OPENCASHIER_BOOTSTRAP_PROVIDER_CONFIG=1
OPENCASHIER_PROVIDER_GROUP=alipay

# Optional. When present, the quickstart loads this JSON file first and lets env
# values override the same provider fields.
# OPENCASHIER_PROVIDER_CONFIG_FILE=./provider-config.local.json

# Default example: one app-scoped Alipay page-pay config.
ALIPAY_AUTH_MODE=KEY
ALIPAY_PRODUCT_CAPABILITIES=PAGE
ALIPAY_APP_ID=
ALIPAY_PRIVATE_KEY=
ALIPAY_PUBLIC_KEY=
ALIPAY_GATEWAY=https://openapi.alipay.com/gateway.do
